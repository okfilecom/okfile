{
  "rules": [
    {
      "allowed": {
        "origins": [
          "https://www.okfile.com",
          "https://okfile.pages.dev",
          "https://*.okfile.pages.dev"
        ],
        "methods": [
          "GET",
          "HEAD",
          "PUT"
        ],
        "headers": [
          "*"
        ]
      },
      "exposeHeaders": [
        "ETag"
      ],
      "maxAgeSeconds": 3600
    }
  ]
}
